# Copy this file to .env and fill in your values
# Never commit .env to version control

# Server
SERVICE_NAME=fastmcp-production-template
PORT=8000
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mcpdb
DB_POOL_MIN=5
DB_POOL_MAX=20

# Security
ALLOWLIST_PATH=config/allowlist.yaml
API_KEY_ENABLED=true
API_KEY=your-secret-api-key-here

# Observability
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=fastmcp-production-template
